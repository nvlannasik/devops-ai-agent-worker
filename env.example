# AWS SQS
AWS_REGION=ap-southeast-1
SQS_REQUEST_QUEUE_NAME=llm-request.fifo
SQS_RESPONSE_QUEUE_NAME=llm-response.fifo
SQS_REQUEST_DLQ_NAME=llm-request-dlq.fifo
SQS_POLL_WAIT_SECONDS=10
SQS_MAX_MESSAGES=5
# Max messages processed concurrently (poll loop keeps pulling work up to this cap)
SQS_MAX_CONCURRENCY=10
# Visibility timeout for request queue in seconds (default: 300 = 5 minutes)
# Must be > max LLM inference time to prevent duplicate processing
SQS_VISIBILITY_TIMEOUT_SECONDS=300
# After this many receives without a successful delete, SQS moves the message to the DLQ
SQS_MAX_RECEIVE_COUNT=3

# AWS credentials — only needed for local dev, not required when using IRSA/instance role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional, for temporary credentials

# Private LLM (OpenAI-compatible API)
LLM_BASE_URL=http://your-private-llm:8080/v1
LLM_API_KEY=none
LLM_MODEL=gauss-2024-06
LLM_MAX_TOKENS=8096
# Set to true if model requires max_completion_tokens instead of max_tokens
LLM_USE_MAX_COMPLETION_TOKENS=false
# Optional inference params — omit if model doesn't support them
# LLM_TEMPERATURE=0.2
# LLM_TOP_P=1
# LLM_SEED=1

# Log level: error | warn | info | http | debug (default: debug in dev, info in prod)
# LOG_LEVEL=info

# AWS Auth Mode: iam-anywhere | irsa | env | instance-profile (default: iam-anywhere)
# AWS_AUTH_MODE=irsa
#
# Required only for iam-anywhere:
# AWS_TRUST_ANCHOR_ARN=arn:aws:rolesanywhere:...
# AWS_ROLESANYWHERE_PROFILE_ARN=arn:aws:rolesanywhere:...
# AWS_ROLE_ARN=arn:aws:iam::123456789:role/your-role
# CERT_PATH=/certs/tls.crt
# CERT_KEY_PATH=/certs/tls.key
