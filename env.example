# AWS SQS
AWS_REGION=ap-southeast-1
SQS_REQUEST_QUEUE_NAME=llm-request.fifo
SQS_RESPONSE_QUEUE_NAME=llm-response.fifo
SQS_REQUEST_DLQ_NAME=llm-request-dlq.fifo
SQS_POLL_WAIT_SECONDS=10
SQS_MAX_MESSAGES=5

# AWS credentials — only needed for local dev, not required when using IRSA/instance role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional, for temporary credentials

# Private LLM (OpenAI-compatible API)
LLM_BASE_URL=http://your-private-llm:8080/v1
LLM_API_KEY=none
LLM_MODEL=your-model-name
LLM_MAX_TOKENS=8096
